# Copy to .dev.vars for local `wrangler dev`. DO NOT commit .dev.vars.
# These mirror the secrets you set in production via `wrangler secret put`.

NEXUS_TOKEN="choose-a-shared-secret"
CLICKUP_TOKEN="pk_your_personal_token"
# Only needed if you enable the poll backup:
NEXUS_API_KEY="your-nexus-api-key"
